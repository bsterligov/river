#!/usr/bin/env bash
#MISE description="Poll SonarQube CE task and print quality gate result"
set -euo pipefail

REPORT=".scannerwork/report-task.txt"

if [[ ! -f "$REPORT" ]]; then
  echo "ERROR: $REPORT not found — run 'mise run ci:sonar-scan' first." >&2
  exit 1
fi

CE_TASK_URL=$(grep '^ceTaskUrl=' "$REPORT" | cut -d= -f2-)
DASHBOARD_URL=$(grep '^dashboardUrl=' "$REPORT" | cut -d= -f2-)

if [[ -z "$CE_TASK_URL" ]]; then
  echo "ERROR: ceTaskUrl not found in $REPORT" >&2
  exit 1
fi

AUTH=""
if [[ -n "${SONAR_TOKEN:-}" ]]; then
  AUTH="-u ${SONAR_TOKEN}:"
fi

echo "Polling CE task..."
for i in $(seq 1 30); do
  STATUS=$(curl -sf $AUTH "$CE_TASK_URL" | python3 -c "import sys,json; t=json.load(sys.stdin)['task']; print(t['status'])")

  if [[ "$STATUS" == "SUCCESS" ]]; then
    break
  elif [[ "$STATUS" == "FAILED" || "$STATUS" == "CANCELLED" ]]; then
    echo "ERROR: CE task ended with status: $STATUS" >&2
    exit 1
  fi

  echo "  [$i/30] status=$STATUS — waiting 10s..."
  sleep 10
done

if [[ "$STATUS" != "SUCCESS" ]]; then
  echo "ERROR: timed out waiting for CE task to complete." >&2
  exit 1
fi

SERVER_URL=$(grep '^serverUrl=' "$REPORT" | cut -d= -f2-)
PROJECT_KEY=$(grep '^projectKey=' "$REPORT" | cut -d= -f2-)

PR_JSON=$(gh pr view --json number 2>/dev/null || true)
if [[ -n "$PR_JSON" ]]; then
  PR_NUMBER=$(echo "$PR_JSON" | python3 -c "import sys,json; print(json.load(sys.stdin)['number'])")
  GATE_URL="${SERVER_URL}/api/qualitygates/project_status?projectKey=${PROJECT_KEY}&pullRequest=${PR_NUMBER}"
else
  GATE_URL="${SERVER_URL}/api/qualitygates/project_status?projectKey=${PROJECT_KEY}&branch=$(git branch --show-current)"
fi

GATE=$(curl -sf $AUTH "$GATE_URL" | python3 -c "
import sys, json
d = json.load(sys.stdin)['projectStatus']
status = d['status']
print(f'Quality gate: {status}')
for c in d.get('conditions', []):
    if c['status'] == 'ERROR':
        print(f'  FAIL  {c[\"metricKey\"]}: {c.get(\"actualValue\",\"?\")} (threshold {c.get(\"errorThreshold\",\"?\")})')
")

echo "$GATE"
echo "Dashboard: $DASHBOARD_URL"

if echo "$GATE" | grep -q "Quality gate: ERROR"; then
  exit 1
fi
