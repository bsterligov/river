#!/usr/bin/env python3
# MISE description="Recalculate token usage tables in docs/token-usage.md and README.md"
import json, glob, os, re, sqlite3, subprocess, collections
from datetime import datetime, timezone

# ── project root ────────────────────────────────────────────────────────────
project_root = subprocess.check_output(
    ["git", "rev-parse", "--show-toplevel"], text=True
).strip()

# ── Step 1: token events from Claude Code sessions ───────────────────────────
proj_slug = re.sub(r"[^A-Za-z0-9]", "-", project_root.lstrip("/"))
proj = os.path.join(os.path.expanduser("~"), ".claude", "projects", f"-{proj_slug}", "")
files = glob.glob(proj + "*.jsonl")

events = []
for fpath in files:
    with open(fpath) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
            except Exception:
                continue
            if obj.get("type") != "assistant":
                continue
            ts_str = obj.get("timestamp")
            usage = obj.get("message", {}).get("usage")
            if not ts_str or not usage:
                continue
            ts = datetime.fromisoformat(ts_str.replace("Z", "+00:00"))
            events.append((
                ts,
                usage.get("input_tokens", 0),
                usage.get("cache_creation_input_tokens", 0),
                usage.get("cache_read_input_tokens", 0),
                usage.get("output_tokens", 0),
            ))

events.sort(key=lambda x: x[0])

# ── Step 2: RTK compression savings ─────────────────────────────────────────
rtk_events = []
try:
    _rtk_line = subprocess.check_output(
        ["rtk", "config"], text=True, stderr=subprocess.DEVNULL
    ).splitlines()[0]
    _rtk_dir = os.path.dirname(_rtk_line.split("Config:", 1)[1].strip())
    RTK_DB = os.path.join(_rtk_dir, "history.db")
    con = sqlite3.connect(RTK_DB)
    cur = con.execute(
        "SELECT timestamp, saved_tokens FROM commands WHERE project_path = ? ORDER BY timestamp",
        (project_root,),
    )
    for ts_str, saved in cur.fetchall():
        ts = datetime.fromisoformat(ts_str).astimezone(timezone.utc)
        rtk_events.append((ts, saved))
    con.close()
except Exception as e:
    print(f"RTK DB unavailable: {e}")

# ── Step 3: git commits ──────────────────────────────────────────────────────
result = subprocess.run(
    ["git", "log", "--format=%aI|%H|%s"],
    capture_output=True, text=True, cwd=project_root
)
commits = []
for line in result.stdout.strip().splitlines():
    parts = line.split("|", 2)
    if len(parts) == 3:
        ts_str, sha, msg = parts
        ts = datetime.fromisoformat(ts_str).astimezone(timezone.utc)
        commits.append((ts, sha[:8], msg))
commits.sort(key=lambda x: x[0])

# ── Step 4: correlate by timestamp window ───────────────────────────────────
boundaries = [None] + [c[0] for c in commits]

rows = []
for i, (commit_ts, sha, msg) in enumerate(commits):
    prev_ts = boundaries[i]
    window = [e for e in events if (prev_ts is None or e[0] > prev_ts) and e[0] <= commit_ts]
    if not window:
        continue
    rtk_window = [e for e in rtk_events if (prev_ts is None or e[0] > prev_ts) and e[0] <= commit_ts]
    rows.append({
        "sha": sha,
        "date": commit_ts.strftime("%m-%d %H:%M"),
        "commit_ts": commit_ts,
        "input": sum(e[1] for e in window),
        "cache_create": sum(e[2] for e in window),
        "cache_read": sum(e[3] for e in window),
        "output": sum(e[4] for e in window),
        "turns": len(window),
        "rtk_saved": sum(e[1] for e in rtk_window),
        "subject": msg[:75],
    })

# ── Step 5: write docs/token-usage.md ───────────────────────────────────────
PRICING = {
    "input":        3.00 / 1e6,
    "cache_create": 3.75 / 1e6,
    "cache_read":   0.30 / 1e6,
    "output":      15.00 / 1e6,
}

def fmt(n):
    return f"{n:,}"

def row_cost(row):
    return (
        row["input"]        * PRICING["input"]
        + row["cache_create"] * PRICING["cache_create"]
        + row["cache_read"]   * PRICING["cache_read"]
        + row["output"]       * PRICING["output"]
    )

today = datetime.now().strftime("%Y-%m-%d")
header = f"# Token Usage — updated {today}\n\n"
header += "**RTKSaved** = tokens removed by RTK compression before reaching Claude (avoided context, on top of billed input).\n\n"

col_headers = "| Date | SHA | Input | CacheC | CacheR | Output | Turns | RTKSaved | Subject |\n"
col_sep     = "|------|-----|------:|-------:|-------:|-------:|------:|---------:|---------|\n"
table = col_headers + col_sep
for r in rows:
    table += (
        f"| {r['date']} | {r['sha']} "
        f"| {fmt(r['input'])} | {fmt(r['cache_create'])} | {fmt(r['cache_read'])} "
        f"| {fmt(r['output'])} | {r['turns']} | {fmt(r['rtk_saved'])} "
        f"| {r['subject']} |\n"
    )

totals = {k: sum(r[k] for r in rows) for k in ("input", "cache_create", "cache_read", "output", "turns", "rtk_saved")}
table += (
    f"| **Total** | — "
    f"| **{fmt(totals['input'])}** | **{fmt(totals['cache_create'])}** | **{fmt(totals['cache_read'])}** "
    f"| **{fmt(totals['output'])}** | **{totals['turns']}** | **{fmt(totals['rtk_saved'])}** | — |\n"
)

# ── Weekly summary table ─────────────────────────────────────────────────────
week_buckets = collections.OrderedDict()
for r in rows:
    iso = r["commit_ts"].isocalendar()
    week_key = f"{iso[0]}-W{iso[1]:02d}"
    if week_key not in week_buckets:
        week_buckets[week_key] = {"input": 0, "cache_create": 0, "cache_read": 0, "output": 0, "turns": 0, "cost": 0.0}
    b = week_buckets[week_key]
    for k in ("input", "cache_create", "cache_read", "output", "turns"):
        b[k] += r[k]
    b["cost"] += row_cost(r)

total_cost = sum(b["cost"] for b in week_buckets.values())

weekly_section = "\n## Weekly Cost\n\n"
weekly_section += "| Week | Input | CacheC | CacheR | Output | Turns | Cost |\n"
weekly_section += "|------|------:|-------:|-------:|-------:|------:|-----:|\n"
for week_key, b in week_buckets.items():
    weekly_section += (
        f"| {week_key} | {fmt(b['input'])} | {fmt(b['cache_create'])} | {fmt(b['cache_read'])} "
        f"| {fmt(b['output'])} | {b['turns']} | ${b['cost']:.2f} |\n"
    )
weekly_section += (
    f"| **Total** | **{fmt(totals['input'])}** | **{fmt(totals['cache_create'])}** "
    f"| **{fmt(totals['cache_read'])}** | **{fmt(totals['output'])}** "
    f"| **{totals['turns']}** | **${total_cost:.2f}** |\n"
)

# ── Per-week files: docs/week-XX.md ─────────────────────────────────────────
docs_dir = os.path.join(project_root, "docs")
for week_key, b in week_buckets.items():
    week_rows = [r for r in rows if f"{r['commit_ts'].isocalendar()[0]}-W{r['commit_ts'].isocalendar()[1]:02d}" == week_key]
    week_cost = b["cost"]
    wf_name = f"week-{week_key}.md"
    wf_path = os.path.join(docs_dir, wf_name)
    wf_lines = f"# Token Usage — {week_key} (${week_cost:.2f})\n\n"
    wf_lines += "| Date | SHA | Input | CacheC | CacheR | Output | Turns | RTKSaved | Cost | Subject |\n"
    wf_lines += "|------|-----|------:|-------:|-------:|-------:|------:|---------:|-----:|---------|\n"
    for r in week_rows:
        rc = row_cost(r)
        wf_lines += (
            f"| {r['date']} | {r['sha']} "
            f"| {fmt(r['input'])} | {fmt(r['cache_create'])} | {fmt(r['cache_read'])} "
            f"| {fmt(r['output'])} | {r['turns']} | {fmt(r['rtk_saved'])} "
            f"| ${rc:.2f} | {r['subject']} |\n"
        )
    wf_lines += (
        f"| **Total** | — "
        f"| **{fmt(b['input'])}** | **{fmt(b['cache_create'])}** | **{fmt(b['cache_read'])}** "
        f"| **{fmt(b['output'])}** | **{b['turns']}** | — | **${week_cost:.2f}** | — |\n"
    )
    with open(wf_path, "w") as f:
        f.write(wf_lines)

# ── Notes section (always regenerated) ──────────────────────────────────────
notes = (
    "\n## Notes\n\n"
    f"- Pricing: Sonnet 4.6 — $3.00/1M input, $3.75/1M cache write, $0.30/1M cache read, $15.00/1M output\n"
    f"- **Total estimated cost: ${total_cost:.4f}**\n"
    "- RTKSaved = tokens removed from tool results before being fed back as context (not billed, but avoided context inflation)\n"
)

usage_path = os.path.join(project_root, "docs", "token-usage.md")
os.makedirs(os.path.dirname(usage_path), exist_ok=True)

with open(usage_path, "w") as f:
    f.write(header + table + weekly_section + notes)

print(f"docs/token-usage.md updated ({len(rows)} commits).")

# ── Step 6: cost breakdown ───────────────────────────────────────────────────
river_map = {}
for root, _, fnames in os.walk(os.path.join(project_root, "specs")):
    parts = root.replace("\\", "/").split("/")
    idx = parts.index("specs") if "specs" in parts else -1
    if idx >= 0 and len(parts) >= idx + 3:
        priority, category = parts[idx + 1], parts[idx + 2]
        for fname in fnames:
            m = re.match(r"RIVER-(\d+)-", fname)
            if m:
                river_map[int(m.group(1))] = (priority, category)

priority_costs = {}
category_costs = {}

for row in rows:
    m = re.search(r"RIVER-(\d+)", row["subject"], re.IGNORECASE)
    if m:
        pri, cat = river_map.get(int(m.group(1)), ("must", "tools"))
    else:
        pri, cat = "must", "tools"
    c = row_cost(row)
    priority_costs[pri] = priority_costs.get(pri, 0) + c
    category_costs[cat] = category_costs.get(cat, 0) + c

# ── Step 7: update README.md tables ─────────────────────────────────────────
readme_path = os.path.join(project_root, "README.md")
with open(readme_path) as f:
    readme = f.read()

all_priorities = ["must", "should", "could", "wont"]
pri_lines = ""
for p in all_priorities:
    c = priority_costs.get(p, 0)
    pri_lines += f"| {p} | ${c:.2f} | {c/total_cost*100:.0f}% |\n" if c > 0 else f"| {p} | — | — |\n"

new_priority_table = f"| Priority | Cost | Share |\n|----------|-----:|------:|\n{pri_lines}"

cat_lines = ""
for cat, c in sorted(category_costs.items(), key=lambda x: -x[1]):
    cat_lines += f"| {cat} | ${c:.2f} | {c/total_cost*100:.0f}% |\n"

new_category_table = f"| Category | Cost | Share |\n|----------|-----:|------:|\n{cat_lines}"

week_lines = ""
for week_key, b in week_buckets.items():
    week_lines += f"| [{week_key}](docs/week-{week_key}.md) | ${b['cost']:.2f} | {b['turns']} |\n"
week_lines += f"| **Total** | **${total_cost:.2f}** | **{totals['turns']}** |\n"
new_weekly_table = f"| Week | Cost | Turns |\n|------|-----:|------:|\n{week_lines}"

readme = re.sub(
    r"\| Priority \| Cost \| Share \|\n\|[-|: ]+\|\n(?:\|.*\|\n)+",
    new_priority_table,
    readme,
)
readme = re.sub(
    r"\| Category \| Cost \| Share \|\n\|[-|: ]+\|\n(?:\|.*\|\n)+",
    new_category_table,
    readme,
)
readme = re.sub(
    r"\| Week \| Cost \| Turns \|\n\|[-|: ]+\|\n(?:\|.*\|\n)+",
    new_weekly_table,
    readme,
)

with open(readme_path, "w") as f:
    f.write(readme)

print("README.md priority/category tables updated.")
