#!/usr/bin/env python3
# MISE description="Block if any impl/* PR is already open; exits 1 if found"
import json, subprocess, sys

result = subprocess.run(
    ["gh", "pr", "list", "--state", "open", "--json", "headRefName"],
    capture_output=True, text=True, check=True,
)
prs = [p["headRefName"] for p in json.loads(result.stdout)
       if p["headRefName"].startswith("impl/")]

if prs:
    print("ERROR: open impl PR(s) already exist:")
    for p in prs:
        print(f"  {p}")
    print("Merge or close them before opening a new one.")
    sys.exit(1)

print("OK: no open impl PRs.")
