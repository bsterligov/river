#!/usr/bin/env python3
# MISE description="Fetch and print unresolved SonarQube issues for the current PR"
import json, os, subprocess, sys, urllib.request, urllib.error

token = os.environ.get("SONAR_TOKEN", "")
if not token:
    print("ERROR: SONAR_TOKEN is not set.", file=sys.stderr)
    sys.exit(1)

pr_result = subprocess.run(
    ["gh", "pr", "view", "--json", "number", "-q", ".number"],
    capture_output=True, text=True, check=True,
)
pr = pr_result.stdout.strip()
if not pr:
    print("ERROR: no open PR found for the current branch.", file=sys.stderr)
    sys.exit(1)

url = (
    f"https://sonarcloud.io/api/issues/search"
    f"?projectKeys=bsterligov_river&pullRequest={pr}&resolved=false"
)
req = urllib.request.Request(url)
import base64
credentials = base64.b64encode(f"{token}:".encode()).decode()
req.add_header("Authorization", f"Basic {credentials}")

try:
    with urllib.request.urlopen(req) as resp:
        data = json.load(resp)
except urllib.error.HTTPError as e:
    print(f"ERROR: SonarCloud API returned {e.code}", file=sys.stderr)
    sys.exit(1)

issues = data.get("issues", [])
print(f"New issues: {len(issues)}")
for i in issues:
    print(f"  [{i['severity']}] {i['type']} — {i['message']}")
    print(f"    {i['component'].split(':')[-1]}:{i.get('line', '?')}")

sys.exit(1 if issues else 0)
