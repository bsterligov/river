{
    "openapi": "3.1.0",
    "info": {
        "title": "river-query-api",
        "description": "",
        "license": {
            "name": ""
        },
        "version": "0.1.0"
    },
    "paths": {
        "/health": {
            "get": {
                "tags": [],
                "operationId": "get_health",
                "responses": {
                    "200": {
                        "description": "Service is healthy"
                    }
                }
            }
        },
        "/v1/logs": {
            "get": {
                "tags": [],
                "operationId": "get_logs",
                "parameters": [
                    {
                        "name": "filter",
                        "in": "query",
                        "description": "Filter expression",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "from",
                        "in": "query",
                        "description": "Start time (RFC 3339)",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "to",
                        "in": "query",
                        "description": "End time (RFC 3339)",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "description": "Max rows (default 100, max 1000)",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int32",
                            "minimum": 0
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Log entries",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/LogRow"
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid filter or timestamp",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorBody"
                                }
                            }
                        }
                    },
                    "503": {
                        "description": "ClickHouse unavailable",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorBody"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v1/metrics": {
            "get": {
                "tags": [],
                "operationId": "get_metrics",
                "parameters": [
                    {
                        "name": "filter",
                        "in": "query",
                        "description": "Filter expression",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "from",
                        "in": "query",
                        "description": "Start time (RFC 3339)",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "to",
                        "in": "query",
                        "description": "End time (RFC 3339)",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "step",
                        "in": "query",
                        "description": "Query step (e.g. 60s, 5m)",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Metric time series points",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/MetricPoint"
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid filter or timestamp",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorBody"
                                }
                            }
                        }
                    },
                    "503": {
                        "description": "VictoriaMetrics unavailable",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorBody"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v1/traces": {
            "get": {
                "tags": [],
                "operationId": "get_traces",
                "parameters": [
                    {
                        "name": "filter",
                        "in": "query",
                        "description": "Filter expression",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "from",
                        "in": "query",
                        "description": "Start time (RFC 3339)",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "to",
                        "in": "query",
                        "description": "End time (RFC 3339)",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "description": "Max spans (default 100, max 1000)",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int32",
                            "minimum": 0
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Traces grouped by trace_id",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/TraceGroup"
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid filter or timestamp",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorBody"
                                }
                            }
                        }
                    },
                    "503": {
                        "description": "ClickHouse unavailable",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorBody"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "ErrorBody": {
                "type": "object",
                "required": [
                    "error"
                ],
                "properties": {
                    "error": {
                        "type": "string"
                    }
                }
            },
            "LogRow": {
                "type": "object",
                "required": [
                    "timestamp",
                    "severity",
                    "service",
                    "body",
                    "trace_id"
                ],
                "properties": {
                    "body": {
                        "type": "string"
                    },
                    "service": {
                        "type": "string"
                    },
                    "severity": {
                        "type": "string"
                    },
                    "timestamp": {
                        "type": "string"
                    },
                    "trace_id": {
                        "type": "string"
                    }
                }
            },
            "MetricPoint": {
                "type": "object",
                "required": [
                    "timestamp",
                    "value"
                ],
                "properties": {
                    "timestamp": {
                        "type": "string"
                    },
                    "value": {
                        "type": "number",
                        "format": "double"
                    }
                }
            },
            "Span": {
                "type": "object",
                "required": [
                    "span_id",
                    "parent_span_id",
                    "service",
                    "operation",
                    "start_time",
                    "end_time",
                    "duration_ms",
                    "status_code",
                    "events",
                    "links"
                ],
                "properties": {
                    "duration_ms": {
                        "type": "number",
                        "format": "double"
                    },
                    "end_time": {
                        "type": "string"
                    },
                    "events": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/SpanEvent"
                        }
                    },
                    "links": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/SpanLink"
                        }
                    },
                    "operation": {
                        "type": "string"
                    },
                    "parent_span_id": {
                        "type": "string"
                    },
                    "service": {
                        "type": "string"
                    },
                    "span_id": {
                        "type": "string"
                    },
                    "start_time": {
                        "type": "string"
                    },
                    "status_code": {
                        "type": "integer",
                        "format": "int64"
                    }
                }
            },
            "SpanEvent": {
                "type": "object",
                "required": [
                    "name",
                    "timestamp",
                    "attributes"
                ],
                "properties": {
                    "attributes": {},
                    "name": {
                        "type": "string"
                    },
                    "timestamp": {
                        "type": "string"
                    }
                }
            },
            "SpanLink": {
                "type": "object",
                "required": [
                    "trace_id",
                    "span_id",
                    "attributes"
                ],
                "properties": {
                    "attributes": {},
                    "span_id": {
                        "type": "string"
                    },
                    "trace_id": {
                        "type": "string"
                    }
                }
            },
            "TraceGroup": {
                "type": "object",
                "required": [
                    "trace_id",
                    "spans"
                ],
                "properties": {
                    "spans": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Span"
                        }
                    },
                    "trace_id": {
                        "type": "string"
                    }
                }
            }
        }
    }
}
